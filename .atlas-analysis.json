{
  "projectType": "sdk-library",
  "projectName": "activerecord-multi-tenant",
  "projectDescription": "A Ruby gem providing ActiveRecord/Rails integration for distributed multi-tenant databases, with native support for the Citus extension for PostgreSQL.",
  "theme": "luma",
